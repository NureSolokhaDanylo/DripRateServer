<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="Page-1">
    <mxGraphModel>
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ==================== COMPONENTS ==================== -->

        <!-- 1. API Layer -->
        <mxCell id="2" value="&lt;b&gt;&amp;laquo;component&amp;raquo;&amp;nbsp; API Layer (ASP.NET Core)&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Controllers (13):&lt;/b&gt; Auth, Publications, Feed, Collections, Wardrobe, Users, Games, Comments, Advertisements, Moderation, Reports, Search, Meta&lt;br&gt;&lt;b&gt;Middlewares:&lt;/b&gt; GlobalExceptionHandler, UserStatusMiddleware&lt;br&gt;&lt;b&gt;OpenApi:&lt;/b&gt; SchemaTypeTransformer, SecurityTransformer, OperationIdTransformer&lt;br&gt;&lt;b&gt;Attributes:&lt;/b&gt; AuthorizeWithError, ApiErrors&lt;br&gt;&lt;b&gt;Program.cs:&lt;/b&gt; DI Registration, Middleware Pipeline, Database Init&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=0;verticalAlign=top;align=left;spacingLeft=6;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="50" y="30" width="780" height="140" as="geometry" />
        </mxCell>

        <!-- 2. Application Layer (CQRS) -->
        <mxCell id="3" value="&lt;b&gt;&amp;laquo;component&amp;raquo;&amp;nbsp; Application Layer (CQRS)&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Commands (17):&lt;/b&gt; Auth, Publications, Collections, Comments, Assessments, Wardrobe, Users, Social, Games, Advertisements, Reports&lt;br&gt;&lt;b&gt;Queries (24):&lt;/b&gt; Auth, Feed, Publications, Collections, Comments, Assessments, Wardrobe, Users, Social, Games, Tags, Advertisements, Moderation, Search&lt;br&gt;&lt;b&gt;Validators (15):&lt;/b&gt; FluentValidation validators for Commands/Queries&lt;br&gt;&lt;b&gt;Behaviors:&lt;/b&gt; ValidationBehavior (pipeline)&lt;br&gt;&lt;b&gt;Internal Services:&lt;/b&gt; FileService, DeletionService&lt;br&gt;&lt;b&gt;DTOs:&lt;/b&gt; AuthDtos, PublicationDtos, CollectionDtos, CommentDtos, ...&lt;/font&gt;&lt;hr&gt;&lt;i&gt;&lt;font style=&quot;font-size: 10px;&quot; color=&quot;#666666&quot;&gt;Defined Ports (Interfaces): IApplicationDbContext, IJwtTokenService, ICurrentUser, IFileStorageService, IStartupScript&lt;/font&gt;&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=0;verticalAlign=top;align=left;spacingLeft=6;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="50" y="210" width="400" height="230" as="geometry" />
        </mxCell>

        <!-- 3. Infrastructure Layer -->
        <mxCell id="4" value="&lt;b&gt;&amp;laquo;component&amp;raquo;&amp;nbsp; Infrastructure Layer&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Persistence:&lt;/b&gt; MyDbContext (EF Core + Identity), Entity Configurations (10), Migrations (29), DatabaseInitializer&lt;br&gt;&lt;b&gt;Authentication:&lt;/b&gt; JwtTokenService, HttpContextCurrentUser&lt;br&gt;&lt;b&gt;Storage:&lt;/b&gt; AzureBlobStorageService&lt;br&gt;&lt;b&gt;Startup Scripts:&lt;/b&gt; SeedRoles, SeedTags, SyncModerators, CleanupCollections&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=0;verticalAlign=top;align=left;spacingLeft=6;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="50" y="500" width="400" height="190" as="geometry" />
        </mxCell>

        <!-- 4. Domain Layer -->
        <mxCell id="5" value="&lt;b&gt;&amp;laquo;component&amp;raquo;&amp;nbsp; Domain Layer&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Entities (16):&lt;/b&gt; User (IdentityUser), Publication, Cloth, Comment, CommentLike, Collection, CollectionPublication, Assessment, Tag, Follow, Report, Advertisement, AdvertisementView, PublicationGameStats, UserGameHistory, GameType&lt;br&gt;&lt;b&gt;Errors (12):&lt;/b&gt; AuthErrors, PublicationErrors, CollectionErrors, CommentErrors, UserErrors, ClothErrors, AssessmentErrors, SocialErrors, ReportErrors, AdvertisementErrors, FileErrors&lt;br&gt;&lt;b&gt;Enums:&lt;/b&gt; CollectionType, GameType, ReportCategory, ReportTargetType, ReportStatus, ModerationAction&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=0;verticalAlign=top;align=left;spacingLeft=6;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="500" y="500" width="330" height="190" as="geometry" />
        </mxCell>

        <!-- 5. SharedSettings -->
        <mxCell id="6" value="&lt;b&gt;&amp;laquo;component&amp;raquo;&amp;nbsp; SharedSettings&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Configuration:&lt;/b&gt; sharedsettings.json, SharedConfiguration&lt;br&gt;&lt;b&gt;Options:&lt;/b&gt; JwtOptions, BlobStorageOptions, FeedOptions, PasswordPolicyOptions&lt;br&gt;&lt;b&gt;Pattern:&lt;/b&gt; Options pattern via IOptions2 interface&lt;br&gt;&lt;i&gt;Referenced by Api, Application, and Infrastructure&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;fontStyle=0;verticalAlign=top;align=left;spacingLeft=6;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="500" y="210" width="330" height="230" as="geometry" />
        </mxCell>

