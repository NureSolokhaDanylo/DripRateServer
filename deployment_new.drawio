<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="Deployment">
    <mxGraphModel>
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Clients -->
        <mxCell id="client" value="User / Mobile App" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="320" y="40" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- Heroku Cloud -->
        <mxCell id="heroku" value="Heroku Cloud" style="swimlane;startSize=30;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="240" y="160" width="320" height="180" as="geometry" />
        </mxCell>
        <mxCell id="web_dyno" value="Web Dyno&#xa;(.NET 10 API)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="heroku">
          <mxGeometry x="80" y="60" width="160" height="80" as="geometry" />
        </mxCell>

        <!-- Azure Cloud -->
        <mxCell id="azure" value="Azure Cloud" style="swimlane;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="640" y="160" width="320" height="240" as="geometry" />
        </mxCell>
        <mxCell id="sql_db" value="Azure SQL Database&#xa;(Production)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="azure">
          <mxGeometry x="80" y="50" width="160" height="70" as="geometry" />
        </mxCell>
        <mxCell id="blob_storage" value="Azure Blob Storage" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="azure">
          <mxGeometry x="80" y="150" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- Developer -->
        <mxCell id="dev" value="Developer Machine" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="210" width="140" height="80" as="geometry" />
        </mxCell>

        <!-- Connections -->
        <!-- User to API -->
        <mxCell id="conn1" value="HTTPS" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="client" target="web_dyno">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- Dev to Heroku -->
        <mxCell id="conn2" value="Git Push / CLI&#xa;(Manual Deploy)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="dev" target="web_dyno">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Heroku to SQL -->
        <mxCell id="conn3" value="TDS (1433)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.25;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;entryPerimeter=0;" edge="1" parent="1" source="web_dyno" target="sql_db">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Heroku to Blob -->
        <mxCell id="conn4" value="Azure SDK&#xa;(HTTPS)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.75;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="web_dyno" target="blob_storage">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
